# App server
APP_NAME=GitLab Copilot MR Reviewer
APP_HOST=0.0.0.0
APP_PORT=8001

# Comma-separated list or JSON array
CORS_ORIGINS=http://localhost:5173

# GitLab
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
PUBLIC_BASE_URL=https://your-public-host.example.com

# Review behavior
REVIEW_TRIGGER_KEYWORD=/copilot-review
DEFAULT_REVIEW_LANGUAGE=Chinese
COPILOT_MODEL=claude-sonnet-4.6
COPILOT_TIMEOUT_SECONDS=3600
INLINE_MIN_SEVERITY=medium

# Storage paths
CLONE_ROOT=backend/repos
CONFIG_STORE_PATH=backend/data/project_configs.json
JOB_STORE_PATH=backend/data/review_jobs.json
JOB_LOGS_DIR=backend/data/job_logs
FRONTEND_DIST_DIR=frontend/dist
